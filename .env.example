# Anthropic (Claude) — scoring engine
ANTHROPIC_API_KEY=sk-ant-...

# Slack — bot token from your Slack app
SLACK_BOT_TOKEN=xoxb-...

# Slack — channel IDs (not names — find via right-click channel > Copy link)
SLACK_CHANNEL_REVIEWS=C0XXXXXX
SLACK_CHANNEL_KILLER=C0XXXXXX

# Fireflies.ai — API key from Settings > Developer
FIREFLIES_API_KEY=...

# Database — Neon Postgres connection string
DATABASE_URL=postgresql://...

# Frontend — URL where the Next.js app is hosted (for Slack deep links)
APP_URL=http://localhost:3001

# Server
PORT=3000
